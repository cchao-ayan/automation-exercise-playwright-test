{
  "name": "automationexercise",
  "version": "1.0.0",
  "description": "Playwright TypeScript test automation project for automationexercise.com",
  "main": "index.js",
  "scripts": {
    "pw:run": "playwright test",
    "pw:api": "playwright test tests/api/test.spec.ts",
    "pw:run:headed": "playwright test --headed",
    "pw:ui": "playwright test --ui",
    "pw:scenario": "playwright test tests/e2e/scenarios.spec.ts",
    "pw:login": "playwright test tests/functional/login.spec.ts",
    "pw:scenario:ui": "playwright test tests/scenarios.spec.ts --ui",
    "pw:codegen": "playwright codegen automationexercise.com",
    "pw:headed": "playwright test --headed",
    "pw:debug": "playwright test --debug",
    "pw:report": "playwright show-report",
    "lint": "eslint \"**/*.{ts,tsx}\" --max-warnings=0",
    "format": "prettier --write \"**/*.{ts,js,json,md}\""
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^24.10.1",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^9.0.0",
    "prettier": "^3.1.0",
    "typescript": "^6.0.0"
  },
  "dependencies": {
    "csv-parse": "^6.2.1",
    "dotenv": "^17.2.3",
    "tsconfig-paths": "^4.2.0",
    "xlsx": "^0.18.5"
  }
}
